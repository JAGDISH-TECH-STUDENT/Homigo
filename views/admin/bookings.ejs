<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --airbnb-red: #FF5A5F;
        --airbnb-dark: #484848;
        --airbnb-light: #767676;
        --airbnb-border: #EBEBEB;
        --airbnb-bg: #F7F7F7;
        --airbnb-white: #FFFFFF;
        --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.15);
        --transition: all 0.3s ease;
    }

    .admin-page {
        background-color: var(--airbnb-bg);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: var(--airbnb-white);
        padding: 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--airbnb-dark);
        margin-bottom: 0.5rem;
    }

    .page-header p {
        color: var(--airbnb-light);
        margin: 0;
    }

    .btn-back {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 500;
        transition: var(--transition);
    }

    .btn-back:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .content-card {
        background: var(--airbnb-white);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
        overflow: hidden;
    }

    .content-card .card-header {
        background: var(--airbnb-white);
        border-bottom: 1px solid var(--airbnb-border);
        padding: 1.25rem 1.5rem;
    }

    .content-card .card-header h5 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        margin: 0;
    }

    .search-box {
        position: relative;
        width: 300px;
    }

    .search-box input {
        border: 1px solid var(--airbnb-border);
        border-radius: 12px;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.9rem;
        transition: var(--transition);
    }

    .search-box input:focus {
        outline: none;
        border-color: var(--airbnb-dark);
        box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
    }

    .search-box i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--airbnb-light);
    }

    .bookings-table {
        margin: 0;
    }

    .bookings-table thead th {
        background: var(--airbnb-bg);
        border: none;
        padding: 1.25rem 1.75rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .bookings-table tbody td {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--airbnb-border);
        vertical-align: middle;
    }

    .bookings-table tbody tr:last-child td {
        border-bottom: none;
    }

    .bookings-table tbody tr:hover {
        background-color: var(--airbnb-bg);
    }

    .booking-id {
        background-color: var(--airbnb-bg);
        color: var(--airbnb-dark);
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
    }

    .listing-link {
        color: var(--airbnb-dark);
        text-decoration: none;
        font-weight: 500;
        transition: var(--transition);
    }

    .listing-link:hover {
        color: var(--airbnb-red);
    }

    .user-info {
        display: flex;
        flex-direction: column;
    }

    .user-name {
        font-weight: 600;
        color: var(--airbnb-dark);
    }

    .user-email {
        color: var(--airbnb-light);
        font-size: 0.85rem;
    }

    .date-range {
        color: var(--airbnb-light);
        font-size: 0.9rem;
    }

    .total-price {
        color: var(--airbnb-red);
        font-weight: 600;
        font-size: 1.1rem;
    }

    .btn-action {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: var(--transition);
        border: none;
    }

    .btn-view {
        background: #E4E9FF;
        color: #667eea;
    }

    .btn-view:hover {
        background: #c4cafe;
    }

    .btn-delete {
        background: var(--airbnb-red);
        color: white;
    }

    .btn-delete:hover {
        background: #E04E53;
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 1.5rem;
        }

        .page-header h1 {
            font-size: 1.5rem;
        }

        .search-box {
            width: 100%;
            margin-top: 1rem;
        }
    }
</style>

<div class="admin-page">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1><i class="fas fa-calendar-check me-2"></i>Booking Management</h1>
                    <p>Manage all bookings on the platform</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="/admin/dashboard" class="btn-back">
                        <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- Bookings Table -->
        <div class="content-card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <h5 class="mb-0">All Bookings (<%= bookings.length %>)</h5>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="bookingSearch" placeholder="Search bookings...">
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table bookings-table mb-0">
                        <thead>
                            <tr>
                                <th>Booking ID</th>
                                <th>Listing</th>
                                <th>User</th>
                                <th>Dates</th>
                                <th>Total</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let booking of bookings) { %>
                            <tr>
                                <td>
                                    <span class="booking-id">#<%= booking._id.toString().slice(-6) %></span>
                                </td>
                                <td>
                                    <% if(booking.listing) { %>
                                    <a href="/admin/listings/<%= booking.listing._id %>/edit" class="listing-link">
                                        <%= booking.listing.title %>
                                    </a>
                                    <% } else { %>
                                    <span class="text-muted">Listing deleted</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(booking.user) { %>
                                    <div class="user-info">
                                        <span class="user-name"><%= booking.user.username %></span>
                                        <span class="user-email"><%= booking.user.email %></span>
                                    </div>
                                    <% } else { %>
                                    <span class="text-muted">User deleted</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="date-range">
                                        <i class="fas fa-calendar-alt me-1"></i>
                                        <%= booking.checkIn.toLocaleDateString() %> - <%= booking.checkOut.toLocaleDateString() %>
                                    </div>
                                </td>
                                <td>
                                    <span class="total-price">$<%= booking.totalPrice %></span>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <% if(booking.listing) { %>
                                        <a href="/admin/listings/<%= booking.listing._id %>/edit" class="btn-action btn-view">
                                            <i class="fas fa-eye me-1"></i>View
                                        </a>
                                        <% } %>
                                        <form action="/admin/bookings/<%= booking._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this booking?');">
                                            <button type="submit" class="btn-action btn-delete">
                                                <i class="fas fa-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('bookingSearch').addEventListener('keyup', function() {
    const searchTerm = this.value.toLowerCase();
    const rows = document.querySelectorAll('tbody tr');
    
    rows.forEach(row => {
        const bookingId = row.querySelector('td:first-child').textContent.toLowerCase();
        const listing = row.querySelector('td:nth-child(2)').textContent.toLowerCase();
        const user = row.querySelector('td:nth-child(3)').textContent.toLowerCase();
        
        if(bookingId.includes(searchTerm) || listing.includes(searchTerm) || user.includes(searchTerm)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
});
</script>
