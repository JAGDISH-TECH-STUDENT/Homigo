<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --airbnb-red: #FF5A5F;
        --airbnb-dark: #484848;
        --airbnb-light: #767676;
        --airbnb-border: #EBEBEB;
        --airbnb-bg: #F7F7F7;
        --airbnb-white: #FFFFFF;
        --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.15);
        --shadow-lg: 0 8px 28px rgba(0,0,0,0.18);
        --transition: all 0.3s ease;
    }

    .admin-dashboard {
        background-color: var(--airbnb-bg);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .dashboard-header {
        background: linear-gradient(135deg, var(--airbnb-red) 0%, #E04E53 100%);
        color: white;
        padding: 2.5rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-md);
    }

    .dashboard-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .dashboard-header p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin: 0;
    }

    .stat-card {
        background: var(--airbnb-white);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        border: 1px solid var(--airbnb-border);
        height: 100%;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
    }

    .stat-card .icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .stat-card .icon-wrapper.users {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .stat-card .icon-wrapper.listings {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .stat-card .icon-wrapper.bookings {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }

    .stat-card .icon-wrapper.reviews {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
    }

    .stat-card .icon-wrapper i {
        font-size: 1.5rem;
        color: white;
    }

    .stat-card h3 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--airbnb-dark);
        margin-bottom: 0.25rem;
    }

    .stat-card p {
        color: var(--airbnb-light);
        font-size: 0.9rem;
        margin: 0;
    }

    .stat-card .view-all {
        display: inline-flex;
        align-items: center;
        color: var(--airbnb-red);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        margin-top: 1rem;
        transition: var(--transition);
    }

    .stat-card .view-all:hover {
        color: #E04E53;
    }

    .stat-card .view-all i {
        margin-left: 0.5rem;
        transition: var(--transition);
    }

    .stat-card .view-all:hover i {
        transform: translateX(4px);
    }

    .content-card {
        background: var(--airbnb-white);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
        overflow: hidden;
        height: 100%;
    }

    .content-card .card-header {
        background: var(--airbnb-white);
        border-bottom: 1px solid var(--airbnb-border);
        padding: 1.25rem 1.5rem;
    }

    .content-card .card-header h5 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        margin: 0;
        display: flex;
        align-items: center;
    }

    .content-card .card-header h5 i {
        margin-right: 0.75rem;
        color: var(--airbnb-red);
    }

    .content-card .card-body {
        padding: 1.5rem;
    }

    .user-distribution .list-group-item {
        border: none;
        padding: 1rem 0;
        border-bottom: 1px solid var(--airbnb-border);
    }

    .user-distribution .list-group-item:last-child {
        border-bottom: none;
    }

    .user-distribution .badge {
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 20px;
    }

    .recent-table {
        margin: 0;
    }

    .recent-table thead th {
        background: var(--airbnb-bg);
        border: none;
        padding: 1.25rem 1.75rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .recent-table tbody td {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--airbnb-border);
        vertical-align: middle;
    }

    .recent-table tbody tr:last-child td {
        border-bottom: none;
    }

    .recent-table tbody tr:hover {
        background-color: var(--airbnb-bg);
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1rem;
        color: white;
    }

    .avatar-circle.admin {
        background: linear-gradient(135deg, #FF5A5F 0%, #E04E53 100%);
    }

    .avatar-circle.host {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .avatar-circle.guest {
        background: linear-gradient(135deg, #767676 0%, #484848 100%);
    }

    .role-badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        text-transform: capitalize;
    }

    .role-badge.admin {
        background-color: #FFE4E4;
        color: var(--airbnb-red);
    }

    .role-badge.host {
        background-color: #E4E9FF;
        color: #667eea;
    }

    .role-badge.guest {
        background-color: #E8E8E8;
        color: var(--airbnb-light);
    }

    .btn-edit {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: var(--transition);
    }

    .btn-edit:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .listing-item {
        padding: 1rem 0;
        border-bottom: 1px solid var(--airbnb-border);
    }

    .listing-item:last-child {
        border-bottom: none;
    }

    .listing-item a {
        text-decoration: none;
        color: var(--airbnb-dark);
        transition: var(--transition);
    }

    .listing-item a:hover {
        color: var(--airbnb-red);
    }

    .listing-item h6 {
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .listing-item small {
        color: var(--airbnb-light);
    }

    .listing-item .price {
        color: var(--airbnb-red);
        font-weight: 600;
    }

    .booking-item {
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--airbnb-border);
    }

    .booking-item:last-child {
        border-bottom: none;
    }

    .booking-item h6 {
        font-weight: 600;
        margin-bottom: 0.25rem;
        color: var(--airbnb-dark);
    }

    .booking-item small {
        color: var(--airbnb-light);
    }

    .booking-item .price {
        color: var(--airbnb-red);
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: var(--airbnb-light);
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    @media (max-width: 768px) {
        .dashboard-header {
            padding: 1.5rem;
        }

        .dashboard-header h1 {
            font-size: 1.75rem;
        }

        .stat-card {
            margin-bottom: 1rem;
        }
    }
</style>

<div class="admin-dashboard">
    <div class="container">
        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1><i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</h1>
                    <p>Welcome back, <%= currUser.username %>! Here's an overview of your platform.</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <span class="badge bg-light text-dark fs-6 px-3 py-2">
                        <i class="fas fa-user-shield me-1"></i>Administrator
                    </span>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="icon-wrapper users">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3><%= totalUsers %></h3>
                    <p>Total Users</p>
                    <a href="/admin/users" class="view-all">
                        View all <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="icon-wrapper listings">
                        <i class="fas fa-home"></i>
                    </div>
                    <h3><%= totalListings %></h3>
                    <p>Total Listings</p>
                    <a href="/admin/listings" class="view-all">
                        View all <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="icon-wrapper bookings">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <h3><%= totalBookings %></h3>
                    <p>Total Bookings</p>
                    <a href="/admin/bookings" class="view-all">
                        View all <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="stat-card">
                    <div class="icon-wrapper reviews">
                        <i class="fas fa-star"></i>
                    </div>
                    <h3><%= totalReviews %></h3>
                    <p>Total Reviews</p>
                    <a href="/admin/reviews" class="view-all">
                        View all <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- User Distribution & Recent Users -->
        <div class="row mb-4">
            <div class="col-lg-4 mb-4">
                <div class="content-card">
                    <div class="card-header">
                        <h5><i class="fas fa-chart-pie"></i>User Distribution</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush user-distribution">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user me-2 text-secondary"></i>
                                    <span class="fw-medium">Guests</span>
                                </div>
                                <span class="badge bg-secondary"><%= guests %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-tie me-2" style="color: #667eea;"></i>
                                    <span class="fw-medium">Hosts</span>
                                </div>
                                <span class="badge" style="background-color: #667eea;"><%= hosts %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fas fa-user-shield me-2" style="color: var(--airbnb-red);"></i>
                                    <span class="fw-medium">Admins</span>
                                </div>
                                <span class="badge" style="background-color: var(--airbnb-red);"><%= admins %></span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-8 mb-4">
                <div class="content-card">
                    <div class="card-header">
                        <h5><i class="fas fa-clock"></i>Recent Users</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table recent-table mb-0">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% for(let user of recentUsers) { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-circle <%= user.role || 'guest' %> me-3">
                                                    <%= user.username.charAt(0).toUpperCase() %>
                                                </div>
                                                <span class="fw-medium"><%= user.username %></span>
                                            </div>
                                        </td>
                                        <td><%= user.email %></td>
                                        <td>
                                            <span class="role-badge <%= user.role || 'guest' %>">
                                                <%= user.role || 'guest' %>
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/admin/users/<%= user._id %>/edit" class="btn-edit">
                                                <i class="fas fa-edit me-1"></i>Edit
                                            </a>
                                        </td>
                                    </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="content-card">
                    <div class="card-header">
                        <h5><i class="fas fa-home"></i>Recent Listings</h5>
                    </div>
                    <div class="card-body">
                        <% if(recentListings.length > 0) { %>
                        <div class="list-group list-group-flush">
                            <% for(let listing of recentListings) { %>
                            <div class="listing-item">
                                <a href="/listings/<%= listing._id %>">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6><%= listing.title %></h6>
                                            <small><i class="fas fa-map-marker-alt me-1"></i><%= listing.location %>, <%= listing.country %></small>
                                        </div>
                                        <span class="price">$<%= listing.price %>/night</span>
                                    </div>
                                </a>
                            </div>
                            <% } %>
                        </div>
                        <% } else { %>
                        <div class="empty-state">
                            <i class="fas fa-home"></i>
                            <p>No listings yet</p>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="content-card">
                    <div class="card-header">
                        <h5><i class="fas fa-calendar"></i>Recent Bookings</h5>
                    </div>
                    <div class="card-body">
                        <% if(recentBookings.length > 0) { %>
                        <div class="list-group list-group-flush">
                            <% for(let booking of recentBookings) { %>
                            <div class="booking-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6>Booking #<%= booking._id.toString().slice(-6) %></h6>
                                        <small>
                                            <i class="fas fa-calendar-alt me-1"></i>
                                            <%= booking.checkIn.toLocaleDateString() %> - <%= booking.checkOut.toLocaleDateString() %>
                                        </small>
                                    </div>
                                    <span class="price">$<%= booking.totalPrice %></span>
                                </div>
                            </div>
                            <% } %>
                        </div>
                        <% } else { %>
                        <div class="empty-state">
                            <i class="fas fa-calendar"></i>
                            <p>No bookings yet</p>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
