<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --airbnb-red: #FF5A5F;
        --airbnb-dark: #484848;
        --airbnb-light: #767676;
        --airbnb-border: #EBEBEB;
        --airbnb-bg: #F7F7F7;
        --airbnb-white: #FFFFFF;
        --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.15);
        --transition: all 0.3s ease;
    }

    .admin-page {
        background-color: var(--airbnb-bg);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: var(--airbnb-white);
        padding: 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--airbnb-dark);
        margin-bottom: 0.5rem;
    }

    .page-header p {
        color: var(--airbnb-light);
        margin: 0;
    }

    .btn-back {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 500;
        transition: var(--transition);
    }

    .btn-back:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .content-card {
        background: var(--airbnb-white);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
        overflow: hidden;
    }

    .content-card .card-header {
        background: var(--airbnb-white);
        border-bottom: 1px solid var(--airbnb-border);
        padding: 1.25rem 1.5rem;
    }

    .content-card .card-header h5 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        margin: 0;
    }

    .content-card .card-body {
        padding: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: var(--airbnb-dark);
        margin-bottom: 0.5rem;
    }

    .form-control-plaintext {
        color: var(--airbnb-dark);
        font-size: 0.95rem;
    }

    .listing-image {
        width: 100%;
        max-height: 300px;
        object-fit: cover;
        border-radius: 12px;
    }

    .btn-info {
        background: #E4E9FF;
        color: #667eea;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        transition: var(--transition);
    }

    .btn-info:hover {
        background: #c4cafe;
    }

    .btn-primary {
        background: var(--airbnb-red);
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        transition: var(--transition);
    }

    .btn-primary:hover {
        background: #E04E53;
    }

    .btn-danger {
        background: var(--airbnb-red);
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        transition: var(--transition);
    }

    .btn-danger:hover {
        background: #E04E53;
    }

    .listing-details .list-group-item {
        border: none;
        padding: 1rem 0;
        border-bottom: 1px solid var(--airbnb-border);
    }

    .listing-details .list-group-item:last-child {
        border-bottom: none;
    }

    .owner-badge {
        background-color: #E4E9FF;
        color: #667eea;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
    }

    .quick-actions .btn {
        width: 100%;
        margin-bottom: 0.5rem;
    }

    .quick-actions .btn:last-child {
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 1.5rem;
        }

        .page-header h1 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="admin-page">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1><i class="fas fa-home me-2"></i>Edit Listing</h1>
                    <p>View and manage listing details</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="/admin/listings" class="btn-back">
                        <i class="fas fa-arrow-left me-1"></i>Back to Listings
                    </a>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="content-card">
                    <div class="card-header">
                        <h5><i class="fas fa-info-circle me-2"></i>Listing Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Title</label>
                                <p class="form-control-plaintext"><%= listing.title %></p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Price</label>
                                <p class="form-control-plaintext">$<%= listing.price %>/night</p>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Location</label>
                                <p class="form-control-plaintext"><%= listing.location %></p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Country</label>
                                <p class="form-control-plaintext"><%= listing.country %></p>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <p class="form-control-plaintext"><%= listing.description %></p>
                        </div>
                        
                        <% if(listing.image && listing.image.url) { %>
                        <div class="mb-3">
                            <label class="form-label">Image</label>
                            <div>
                                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-image">
                            </div>
                        </div>
                        <% } %>
                        
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="/listings/<%= listing._id %>" class="btn btn-info">
                                <i class="fas fa-eye me-1"></i>View Public Page
                            </a>
                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
                                <i class="fas fa-edit me-1"></i>Edit Listing
                            </a>
                            <form action="/admin/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this listing? This will also delete all associated bookings and reviews.');">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash me-1"></i>Delete Listing
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="content-card mb-4">
                    <div class="card-header">
                        <h5><i class="fas fa-id-card me-2"></i>Listing Details</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush listing-details">
                            <li class="list-group-item d-flex justify-content-between">
                                <span>Listing ID:</span>
                                <span class="text-muted"><%= listing._id.toString().slice(-8) %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span>Owner:</span>
                                <span class="owner-badge"><%= listing.owner ? listing.owner.username : 'Unknown' %></span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span>Owner Email:</span>
                                <span class="text-muted"><%= listing.owner ? listing.owner.email : 'N/A' %></span>
                            </li>
                        </ul>
                    </div>
                </div>
                
                <div class="content-card">
                    <div class="card-header">
                        <h5><i class="fas fa-bolt me-2"></i>Quick Actions</h5>
                    </div>
                    <div class="card-body quick-actions">
                        <a href="/listings/<%= listing._id %>" class="btn btn-info">
                            <i class="fas fa-external-link-alt me-1"></i>View Public Page
                        </a>
                        <a href="/admin/listings" class="btn btn-secondary">
                            <i class="fas fa-list me-1"></i>All Listings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
