<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --airbnb-red: #FF5A5F;
        --airbnb-dark: #484848;
        --airbnb-light: #767676;
        --airbnb-border: #EBEBEB;
        --airbnb-bg: #F7F7F7;
        --airbnb-white: #FFFFFF;
        --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.15);
        --transition: all 0.3s ease;
    }

    .admin-page {
        background-color: var(--airbnb-bg);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: var(--airbnb-white);
        padding: 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--airbnb-dark);
        margin-bottom: 0.5rem;
    }

    .page-header p {
        color: var(--airbnb-light);
        margin: 0;
    }

    .btn-back {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 500;
        transition: var(--transition);
    }

    .btn-back:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .content-card {
        background: var(--airbnb-white);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
        overflow: hidden;
    }

    .content-card .card-header {
        background: var(--airbnb-white);
        border-bottom: 1px solid var(--airbnb-border);
        padding: 1.5rem 2rem;
    }

    .content-card .card-header h5 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        margin: 0;
    }

    .search-box {
        position: relative;
        width: 300px;
    }

    .search-box input {
        border: 1px solid var(--airbnb-border);
        border-radius: 12px;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.9rem;
        transition: var(--transition);
    }

    .search-box input:focus {
        outline: none;
        border-color: var(--airbnb-dark);
        box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
    }

    .search-box i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--airbnb-light);
    }

    .listings-table {
        margin: 0;
    }

    .listings-table thead th {
        background: var(--airbnb-bg);
        border: none;
        padding: 1.25rem 1.75rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .listings-table tbody td {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--airbnb-border);
        vertical-align: middle;
    }

    .listings-table tbody tr:last-child td {
        border-bottom: none;
    }

    .listings-table tbody tr:hover {
        background-color: var(--airbnb-bg);
    }

    .listing-image {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        object-fit: cover;
    }

    .listing-image-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .listing-title {
        font-weight: 600;
        color: var(--airbnb-dark);
        margin-bottom: 0.25rem;
    }

    .listing-location {
        color: var(--airbnb-light);
        font-size: 0.85rem;
    }

    .listing-price {
        color: var(--airbnb-red);
        font-weight: 600;
        font-size: 1.1rem;
    }

    .owner-badge {
        background-color: #E4E9FF;
        color: #667eea;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
    }

    .btn-action {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: var(--transition);
        border: none;
    }

    .btn-view {
        background: #E4E9FF;
        color: #667eea;
    }

    .btn-view:hover {
        background: #c4cafe;
    }

    .btn-edit {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
    }

    .btn-edit:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .btn-delete {
        background: var(--airbnb-red);
        color: white;
    }

    .btn-delete:hover {
        background: #E04E53;
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 1.5rem;
        }

        .page-header h1 {
            font-size: 1.5rem;
        }

        .search-box {
            width: 100%;
            margin-top: 1rem;
        }
    }
</style>

<div class="admin-page">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1><i class="fas fa-home me-2"></i>Listing Management</h1>
                    <p>Manage all property listings on the platform</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="/admin/dashboard" class="btn-back">
                        <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- Listings Table -->
        <div class="content-card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <h5 class="mb-0">All Listings (<%= listings.length %>)</h5>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="listingSearch" placeholder="Search listings...">
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table listings-table mb-0">
                        <thead>
                            <tr>
                                <th>Listing</th>
                                <th>Location</th>
                                <th>Price</th>
                                <th>Owner</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let listing of listings) { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <% if(listing.image && listing.image.url) { %>
                                        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-image me-3">
                                        <% } else { %>
                                        <div class="listing-image-placeholder me-3">
                                            <i class="fas fa-home"></i>
                                        </div>
                                        <% } %>
                                        <div>
                                            <div class="listing-title"><%= listing.title %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="listing-location">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        <%= listing.location %>, <%= listing.country %>
                                    </div>
                                </td>
                                <td>
                                    <span class="listing-price">$<%= listing.price %>/night</span>
                                </td>
                                <td>
                                    <% if(listing.owner) { %>
                                    <span class="owner-badge"><%= listing.owner.username %></span>
                                    <% } else { %>
                                    <span class="text-muted">Unknown</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a href="/listings/<%= listing._id %>" class="btn-action btn-view">
                                            <i class="fas fa-eye me-1"></i>View
                                        </a>
                                        <a href="/admin/listings/<%= listing._id %>/edit" class="btn-action btn-edit">
                                            <i class="fas fa-edit me-1"></i>Edit
                                        </a>
                                        <form action="/admin/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this listing? This will also delete all associated bookings and reviews.');">
                                            <button type="submit" class="btn-action btn-delete">
                                                <i class="fas fa-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('listingSearch').addEventListener('keyup', function() {
    const searchTerm = this.value.toLowerCase();
    const rows = document.querySelectorAll('tbody tr');
    
    rows.forEach(row => {
        const title = row.querySelector('td:first-child').textContent.toLowerCase();
        const location = row.querySelector('td:nth-child(2)').textContent.toLowerCase();
        const owner = row.querySelector('td:nth-child(4)').textContent.toLowerCase();
        
        if(title.includes(searchTerm) || location.includes(searchTerm) || owner.includes(searchTerm)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
});
</script>
