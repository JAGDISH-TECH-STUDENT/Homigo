<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --airbnb-red: #FF5A5F;
        --airbnb-dark: #484848;
        --airbnb-light: #767676;
        --airbnb-border: #EBEBEB;
        --airbnb-bg: #F7F7F7;
        --airbnb-white: #FFFFFF;
        --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.15);
        --transition: all 0.3s ease;
    }

    .admin-page {
        background-color: var(--airbnb-bg);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: var(--airbnb-white);
        padding: 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--airbnb-dark);
        margin-bottom: 0.5rem;
    }

    .page-header p {
        color: var(--airbnb-light);
        margin: 0;
    }

    .btn-back {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 500;
        transition: var(--transition);
    }

    .btn-back:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .content-card {
        background: var(--airbnb-white);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--airbnb-border);
        overflow: hidden;
    }

    .content-card .card-header {
        background: var(--airbnb-white);
        border-bottom: 1px solid var(--airbnb-border);
        padding: 1.5rem 2rem;
    }

    .content-card .card-header h5 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        margin: 0;
    }

    .search-box {
        position: relative;
        width: 300px;
    }

    .search-box input {
        border: 1px solid var(--airbnb-border);
        border-radius: 12px;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        font-size: 0.9rem;
        transition: var(--transition);
    }

    .search-box input:focus {
        outline: none;
        border-color: var(--airbnb-dark);
        box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
    }

    .search-box i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--airbnb-light);
    }

    .users-table {
        margin: 0;
    }

    .users-table thead th {
        background: var(--airbnb-bg);
        border: none;
        padding: 1.25rem 1.75rem;
        font-weight: 600;
        color: var(--airbnb-dark);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .users-table tbody td {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--airbnb-border);
        vertical-align: middle;
    }

    .users-table tbody tr:last-child td {
        border-bottom: none;
    }

    .users-table tbody tr:hover {
        background-color: var(--airbnb-bg);
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1rem;
        color: white;
    }

    .avatar-circle.admin {
        background: linear-gradient(135deg, #FF5A5F 0%, #E04E53 100%);
    }

    .avatar-circle.host {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .avatar-circle.guest {
        background: linear-gradient(135deg, #767676 0%, #484848 100%);
    }

    .role-badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        text-transform: capitalize;
    }

    .role-badge.admin {
        background-color: #FFE4E4;
        color: var(--airbnb-red);
    }

    .role-badge.host {
        background-color: #E4E9FF;
        color: #667eea;
    }

    .role-badge.guest {
        background-color: #E8E8E8;
        color: var(--airbnb-light);
    }

    .you-badge {
        background-color: var(--airbnb-red);
        color: white;
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
        border-radius: 10px;
        margin-left: 0.5rem;
    }

    .btn-action {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: var(--transition);
        border: none;
    }

    .btn-edit {
        background: var(--airbnb-white);
        border: 1px solid var(--airbnb-border);
        color: var(--airbnb-dark);
    }

    .btn-edit:hover {
        background: var(--airbnb-bg);
        border-color: var(--airbnb-dark);
    }

    .btn-delete {
        background: var(--airbnb-red);
        color: white;
    }

    .btn-delete:hover {
        background: #E04E53;
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 1.5rem;
        }

        .page-header h1 {
            font-size: 1.5rem;
        }

        .search-box {
            width: 100%;
            margin-top: 1rem;
        }
    }
</style>

<div class="admin-page">
    <div class="container">
                <div class="page-header">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1><i class="fas fa-users me-2"></i>User Management</h1>
                    <p>Manage all users on the platform</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="/admin/dashboard" class="btn-back">
                        <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

                <div class="content-card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <h5 class="mb-0">All Users (<%= users.length %>)</h5>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="userSearch" placeholder="Search users...">
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table users-table mb-0">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let user of users) { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle <%= user.role || 'guest' %> me-3">
                                            <%= user.username.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <span class="fw-medium"><%= user.username %></span>
                                            <% if(user._id.equals(currUser._id)) { %>
                                            <span class="you-badge">You</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                <td><%= user.email %></td>
                                <td>
                                    <span class="role-badge <%= user.role || 'guest' %>">
                                        <%= user.role || 'guest' %>
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a href="/admin/users/<%= user._id %>/edit" class="btn-action btn-edit">
                                            <i class="fas fa-edit me-1"></i>Edit
                                        </a>
                                        <% if(!user._id.equals(currUser._id)) { %>
                                        <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user? This will also delete all their listings, bookings, and reviews.');">
                                            <button type="submit" class="btn-action btn-delete">
                                                <i class="fas fa-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('userSearch').addEventListener('keyup', function() {
    const searchTerm = this.value.toLowerCase();
    const rows = document.querySelectorAll('tbody tr');
    
    rows.forEach(row => {
        const username = row.querySelector('td:first-child').textContent.toLowerCase();
        const email = row.querySelector('td:nth-child(2)').textContent.toLowerCase();
        
        if(username.includes(searchTerm) || email.includes(searchTerm)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
});
</script>
