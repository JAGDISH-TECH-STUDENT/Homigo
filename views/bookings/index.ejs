<% layout("/layouts/boilerplate")%>

<div class="row mt-4">
    <div class="col-10 offset-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0" style="color: #ffffff; font-weight: 700;">My Bookings</h2>
            <a href="/listings" class="booking-action-btn primary">
                <i class="fa-solid fa-plus"></i> Browse Listings
            </a>
        </div>
    </div>
</div>

<% if(bookings.length === 0) { %>
<div class="row mt-3">
    <div class="col-10 offset-1">
        <div class="booking-empty-state">
            <div class="booking-empty-icon">
                <i class="fa-solid fa-calendar-xmark"></i>
            </div>
            <h3 class="booking-empty-title">No bookings yet</h3>
            <p class="booking-empty-text">You haven't made any bookings yet. Start exploring amazing places to stay!</p>
            <a href="/listings" class="booking-empty-btn">
                <i class="fa-solid fa-search"></i> Browse Listings
            </a>
        </div>
    </div>
</div>
<% } else { %>
<div class="row mt-3">
    <div class="col-10 offset-1">
        <div class="row">
            <% for(let booking of bookings) { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="booking-list-card">
                        <img src="<%= booking.listing ? booking.listing.image.url : '' %>" class="booking-list-img" alt="<%= booking.listing ? booking.listing.title : 'Listing' %>">
                        <div class="booking-list-body">
                            <h5 class="booking-list-title"><%= booking.listing ? booking.listing.title : 'Listing' %></h5>
                            <div class="booking-list-details">
                                <div class="booking-detail-row">
                                    <span class="booking-detail-label">Check-in</span>
                                    <span class="booking-detail-value"><%= new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                </div>
                                <div class="booking-detail-row">
                                    <span class="booking-detail-label">Check-out</span>
                                    <span class="booking-detail-value"><%= new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                </div>
                                <div class="booking-detail-row">
                                    <span class="booking-detail-label">Guests</span>
                                    <span class="booking-detail-value"><%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></span>
                                </div>
                                <%
                                    const checkInDate = new Date(booking.checkIn);
                                    const checkOutDate = new Date(booking.checkOut);
                                    const nights = Math.round((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));
                                    const pricePerNight = booking.listing ? booking.listing.price : 0;
                                    const rentalPrice = pricePerNight * nights;
                                    const serviceFee = Math.round(rentalPrice * 0.12);
                                    const calculatedTotal = rentalPrice + serviceFee;
                                %>
                                <div class="booking-detail-row">
                                    <span class="booking-detail-label">Rental Price</span>
                                    <span class="booking-detail-value">&#8377;<%= rentalPrice.toLocaleString("en-IN") %></span>
                                </div>
                                <div class="booking-detail-row">
                                    <span class="booking-detail-label">Service Fee (12%)</span>
                                    <span class="booking-detail-value">&#8377;<%= serviceFee.toLocaleString("en-IN") %></span>
                                </div>
                                <div class="booking-detail-row">
                                    <span class="booking-detail-label">Total Price</span>
                                    <span class="booking-detail-value">&#8377;<%= calculatedTotal.toLocaleString("en-IN") %></span>
                                </div>
                            </div>
                            <div class="booking-list-status">
                                <span class="booking-status-badge status-<%= booking.status %>">
                                    <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                                </span>
                            </div>
                        </div>
                        <div class="booking-list-footer">
                            <span class="booking-list-date">
                                <i class="fa-regular fa-clock"></i> Booked on <%= new Date(booking.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                            </span>
                            <div class="booking-list-actions">
                                <a href="/bookings/<%= booking._id %>" class="booking-action-btn secondary">View</a>
                                <% if(booking.status === 'pending') { %>
                                    <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" class="d-inline">
                                        <button type="submit" class="booking-action-btn danger" onclick="return confirm('Are you sure you want to delete this booking? This action cannot be undone.')">Delete</button>
                                    </form>
                                <% } else if(booking.status === 'confirmed') { %>
                                    <form method="POST" action="/bookings/<%= booking._id %>/cancel" class="d-inline">
                                        <button type="submit" class="booking-action-btn danger" onclick="return confirm('Are you sure you want to cancel this booking?')">Cancel</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>
<% } %>
