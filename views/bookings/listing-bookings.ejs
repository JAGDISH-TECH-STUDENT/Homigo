<% layout("/layouts/boilerplate")%>

<div class="row mt-4">
    <div class="col-10 offset-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0" style="color: #ffffff; font-weight: 700;">Bookings for "<%= listing.title %>"</h2>
            <a href="/host/dashboard" class="booking-action-btn primary">
                <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-10 offset-1">
        <% if(bookings.length === 0) { %>
            <div class="booking-empty-state">
                <div class="booking-empty-icon">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <h3 class="booking-empty-title">No bookings yet</h3>
                <p class="booking-empty-text">When guests book this listing, their requests will appear here.</p>
            </div>
        <% } else { %>
            <div class="row">
                <% for(let booking of bookings) { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="booking-list-card">
                            <div class="booking-list-body">
                                <h5 class="booking-list-title">Booking #<%= booking._id.toString().slice(-6).toUpperCase() %></h5>
                                <div class="booking-list-details">
                                    <div class="booking-detail-row">
                                        <span class="booking-detail-label">Guest</span>
                                        <span class="booking-detail-value">@<%= booking.user ? booking.user.username : 'Unknown' %></span>
                                    </div>
                                    <div class="booking-detail-row">
                                        <span class="booking-detail-label">Check-in</span>
                                        <span class="booking-detail-value"><%= new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                    </div>
                                    <div class="booking-detail-row">
                                        <span class="booking-detail-label">Check-out</span>
                                        <span class="booking-detail-value"><%= new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                    </div>
                                    <div class="booking-detail-row">
                                        <span class="booking-detail-label">Guests</span>
                                        <span class="booking-detail-value"><%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></span>
                                    </div>
                                    <div class="booking-detail-row">
                                        <span class="booking-detail-label">Total Price</span>
                                        <span class="booking-detail-value">&#8377;<%= booking.totalPrice ? booking.totalPrice.toLocaleString("en-IN") : "0" %></span>
                                    </div>
                                </div>
                                <div class="booking-list-status">
                                    <span class="booking-status-badge status-<%= booking.status %>">
                                        <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                                    </span>
                                </div>
                            </div>
                            <div class="booking-list-footer">
                                <span class="booking-list-date">
                                    <i class="fa-regular fa-clock"></i> Requested on <%= new Date(booking.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                </span>
                                <div class="booking-list-actions">
                                    <% if(booking.status === 'pending') { %>
                                        <form method="POST" action="/host/bookings/<%= booking._id %>/confirm" class="d-inline">
                                            <button type="submit" class="booking-action-btn primary">Confirm</button>
                                        </form>
                                        <form method="POST" action="/host/bookings/<%= booking._id %>/reject" class="d-inline">
                                            <button type="submit" class="booking-action-btn danger" onclick="return confirm('Are you sure you want to reject this booking?')">Reject</button>
                                        </form>
                                    <% } else if(booking.status === 'confirmed') { %>
                                        <span class="text-success"><i class="fa-solid fa-check-circle"></i> Confirmed</span>
                                    <% } else if(booking.status === 'rejected') { %>
                                        <span class="text-danger"><i class="fa-solid fa-times-circle"></i> Rejected</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</div>
